# Copy to .env.local and fill in. Do not commit real secrets.

# Resend (https://resend.com) — transactional email for the contact form.
RESEND_API_KEY=

# Where contact-form submissions are delivered.
CONTACT_TO=support@alivespectra.com

# Sender. Must be a verified-domain address in production
# (e.g. "Alive Spectra <hello@alivespectra.com>"). For testing without a
# verified domain, use "Alive Spectra <onboarding@resend.dev>".
RESEND_FROM=Alive Spectra <onboarding@resend.dev>
